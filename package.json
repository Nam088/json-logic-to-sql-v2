{
  "name": "@nam088/json-logic-sql",
  "version": "1.3.0",
  "description": "Zero-trust JSON Logic to parameterized SQL converter",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nam088/json-logic-to-sql-v2.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "vitest",
    "release": "semantic-release"
  },
  "keywords": [
    "json-logic",
    "sql",
    "query-builder",
    "filter",
    "security"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.58.9",
    "@mikro-orm/core": "^7.1.4",
    "@mikro-orm/postgresql": "^7.1.4",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/express": "^5.0.6",
    "@types/mssql": "^12.3.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "express": "^5.2.1",
    "mssql": "^12.5.5",
    "mysql2": "^3.22.5",
    "pg": "^8.21.0",
    "pg-hstore": "^2.3.4",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "reflect-metadata": "^0.2.2",
    "semantic-release": "^25.0.5",
    "sequelize": "^6.37.8",
    "typeorm": "^1.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vitest": "^4.1.8"
  }
}
